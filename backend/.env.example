# Scaffold Arena — Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: at least one provider API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key (required only for OpenAI models)
OPENAI_API_KEY=sk-proj-...

# Optional: Gemini API key (required only for Gemini models)
GEMINI_API_KEY=...

# Optional: OpenRouter API key (required only for OpenRouter models)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: OpenAI-compatible transport config
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Scaffold Arena

# App environment (dev | production)
APP_ENV=dev

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# API auth (required in production; bearer token on mutating endpoints)
API_SECRET_KEY=change-me

# Default models
DEFAULT_MAIN_MODEL_ID=claude-sonnet-4-6
DEFAULT_CHEAP_MODEL_ID=claude-haiku-4-5

# Feature flags
ENABLE_LLM_JUDGE=true
ENABLE_PDF_EXPORT=false

# Rate limiting
MAX_CONCURRENT_LLM_CALLS=3

# Budget and limits
MAX_COST_PER_RUN_USD=2.0
DAILY_BUDGET_USD=50.0
MAX_REQUEST_SIZE_BYTES=1000000
RUN_TTL_SECONDS=1800
PROVIDER_MAX_RETRIES=3
PROVIDER_RETRY_BASE_DELAY_MS=250
SQLITE_PATH=data/scaffold_arena.db
LOG_LEVEL=INFO
