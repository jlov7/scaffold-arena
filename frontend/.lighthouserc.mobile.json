{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm preview --host 127.0.0.1 --port 4318",
      "startServerReadyPattern": "Local",
      "url": [
        "http://127.0.0.1:4318/arena",
        "http://127.0.0.1:4318/settings"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "perf",
        "formFactor": "mobile",
        "throttlingMethod": "simulate",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638,
          "cpuSlowdownMultiplier": 4
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
        "interactive": ["warn", { "maxNumericValue": 5000 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-reports/mobile"
    }
  }
}
