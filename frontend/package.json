{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "perf:budget": "node scripts/check-budgets.mjs",
    "perf:lighthouse": "lhci autorun --config=.lighthouserc.json",
    "perf:lighthouse:mobile": "lhci autorun --config=.lighthouserc.mobile.json",
    "report:ux-weekly": "node scripts/generate-ux-regression-report.mjs",
    "check:scorecard-freshness": "node scripts/check-launch-scorecard-freshness.mjs",
    "arch:layers": "node scripts/check-layering.mjs",
    "smoke:prod": "node scripts/prod-smoke.mjs",
    "docs:screenshots": "node scripts/capture-doc-screenshots.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:persona-proxy": "playwright test tests/e2e/persona-session-matrix.spec.ts",
    "test:e2e:mobile-proxy": "playwright test tests/e2e/mobile-validation-matrix.spec.ts",
    "test:first-click": "playwright test tests/e2e/first-click.spec.ts",
    "test:a11y": "playwright test tests/a11y",
    "test:a11y:user-proxy": "playwright test tests/a11y/accessibility-user-proxy.spec.ts",
    "test:visual": "playwright test tests/visual --project=visual",
    "verify:visual": "./scripts/verify-visual.sh",
    "verify:visual:update": "./scripts/verify-visual.sh --update-snapshots",
    "test:design-qa-evidence": "playwright test tests/visual/design-qa-evidence.spec.ts",
    "test:content": "vitest run src/content.lint.test.ts",
    "test:qa": "playwright test",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.0",
    "web-vitals": "^5.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.3"
  }
}
