# Scaffold Arena — Environment Variables
# Copy to .env and fill in your values

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Default model for arena runs
# Options: claude-sonnet-4-6, claude-haiku-4-5
DEFAULT_MODEL_ID=claude-sonnet-4-6

# Optional: Enable LLM judge for evaluation (uses additional API calls)
# When disabled, evaluation uses deterministic metrics only (70%+ weight)
ENABLE_LLM_JUDGE=true

# Optional: Server configuration
HOST=0.0.0.0
PORT=8000
