# Scaffold Arena — Environment Variables
# Copy to .env and fill in your values

# Required: at least one provider API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key (required only for OpenAI models)
OPENAI_API_KEY=sk-proj-...

# Optional: Gemini API key (required only for Gemini models)
GEMINI_API_KEY=...

# Optional: OpenRouter API key (required only for OpenRouter models)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: OpenAI-compatible transport config
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Scaffold Arena

# Optional: Default model for arena runs
# Options: claude-sonnet-4-6, claude-haiku-4-5, gpt-4.1-mini, gpt-4.1, gemini-2.5-flash, gemini-2.5-pro, openrouter/openai/gpt-4.1-mini, openrouter/openai/gpt-4.1
DEFAULT_MODEL_ID=claude-sonnet-4-6

# Optional: Enable LLM judge for evaluation (uses additional API calls)
# When disabled, evaluation uses deterministic metrics only (70%+ weight)
ENABLE_LLM_JUDGE=true

# Optional: Server configuration
HOST=0.0.0.0
PORT=8000

# API auth token for protected POST endpoints
API_SECRET_KEY=change-me

# Frontend token passthrough (Vite)
VITE_API_TOKEN=change-me

# Optional backend operations
SQLITE_PATH=data/scaffold_arena.db
LOG_LEVEL=INFO
